# Anthropic API key — get yours at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# The password users type on the login screen
APP_PASSWORD=choose-something-memorable

# A secret used to sign the auth cookie — generate with: openssl rand -hex 32
APP_SECRET=paste-the-output-here

# Upstash Redis — these are auto-populated when you connect Upstash
# via Vercel Storage in your Vercel project dashboard.
# You don't need to set these manually if using the Vercel integration.
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
